{
  "name": "quantum-loom",
  "version": "1.0.7",
  "description": "A narrative DAW for story, music & world-building",
  "main": "main.js",
  "license": "MIT",
  "author": {
    "name": "Jeremy Dickinson",
    "email": "your-email@example.com"
  },
  "scripts": {
    "start": "electron .",
    "dev": "QL_DEV=1 electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.phantori.quantumloom",
    "productName": "Quantum Loom",
    "copyright": "Copyright © 2026 Phantori",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
