{
  "name": "quantum-loom",
  "version": "1.0.0",
  "description": "A narrative DAW for story, music & world-building",
  "main": "main.js",
  "author": "Phantori",
  "license": "MIT",
  "scripts": {
    "start":       "electron .",
    "dev":         "QL_DEV=1 electron .",
    "build:win":   "electron-builder --win",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all":   "electron-builder --win --mac --linux"
  },
  "build": {
    "extraResources": [
      { "from": "server/", "to": "server/", "filter": ["**/*"] }
    ],
    "appId":       "com.phantori.quantumloom",
    "productName": "Quantum Loom",
    "copyright":   "Copyright © 2026 Phantori",
    "asar":        true,
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "assets/**/*"
    ],
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quantum Loom"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "dmg": {
      "title": "Quantum Loom",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 190, "type": "file" },
        { "x": 400, "y": 190, "type": "link", "path": "/Applications" }
      ]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Education"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
